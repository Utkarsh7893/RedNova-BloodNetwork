# ─── BACKEND (backend/.env) ──────────────────────────────────────────
MONGO_URI=your_mongo_url_here
PORT=3000

# Comma-separated list of allowed frontend origins
# LOCAL:      http://localhost:5173,http://localhost:5174
# PRODUCTION: https://rednovafrontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://rednovafrontend.vercel.app

# ─── FRONTEND (frontend/.env) ─────────────────────────────────────────
# LOCAL  → http://localhost:3000
# HOSTED → https://your-backend.onrender.com
VITE_API_URL=http://localhost:3000